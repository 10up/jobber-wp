{
  "name": "jobber",
  "version": "1.0.0",
  "license": "GPL-2.0-or-later",
  "author": {
    "name": "10up",
    "email": "opensource@10up.com",
    "url": "https://10up.com"
  },
  "scripts": {
    "start": "npm run watch",
    "watch": "10up-toolkit watch --port=5010 --hot",
    "build": "10up-toolkit build",
    "format-js": "10up-toolkit format-js",
    "lint-js": "10up-toolkit lint-js",
    "lint-style": "10up-toolkit lint-style",
    "test": "10up-toolkit test-unit-jest --passWithNoTests",
    "clean-dist": "rm -rf ./dist",
    "archive": "composer archive --file=jobber --format=zip",
    "postarchive": "rm -rf ./release && unzip jobber.zip -d ./release",
    "env": "wp-env",
    "env:start": "wp-env start",
    "env:stop": "wp-env stop",
    "env:destroy": "wp-env destroy",
    "cypress:open": "cypress open --config-file tests/cypress/config.config.js",
    "cypress:run": "cypress run --browser chrome --config-file tests/cypress/config.config.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@10up/cypress-wp-utils": "^0.5.0",
    "@wordpress/env": "^10.20.0",
    "cypress": "^14.2.0",
    "cypress-file-upload": "^5.0.8",
    "cypress-mochawesome-reporter": "^3.8.2",
    "cypress-plugin-tab": "^1.0.5",
    "@10up/babel-preset-default": "^2.1.2",
    "10up-toolkit": "^6.4.1",
    "jest-environment-jsdom": "^29.7.0"
  },
  "dependencies": {
    "@wordpress/icons": "^10.22.0",
    "prop-types": "^15.7.2"
  },
  "10up-toolkit": {
    "entry": {
      "jobber-forms": "./blocks/forms"
    }
  }
}
