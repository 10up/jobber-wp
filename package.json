{
  "name": "jobber-wp",
  "version": "1.0.0",
  "scripts": {
    "start": "npm run watch",
    "watch": "10up-toolkit watch --port=5010 --hot",
    "build": "10up-toolkit build",
    "format-js": "10up-toolkit format-js",
    "lint-js": "10up-toolkit lint-js",
    "lint-style": "10up-toolkit lint-style",
    "test": "10up-toolkit test-unit-jest --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "clean-dist": "rm -rf ./dist",
    "archive": "composer archive --file=$npm_package_name --format=zip",
    "postarchive": "rm -rf ./release && unzip $npm_package_name.zip -d ./release"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@10up/babel-preset-default": "^2.1.2",
    "10up-toolkit": "^6.4.0",
    "@playwright/test": "^1.42.1",
    "@types/node": "^20.11.19",
    "jest-environment-jsdom": "^29.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@wordpress/icons": "^10.22.0",
    "prop-types": "^15.7.2"
  },
  "10up-toolkit": {
    "entry": {
      "admin": "./assets/js/admin/admin.js",
      "jobber-forms": "./blocks/forms"
    }
  }
}
