{
  "name": "jobber-wp",
  "version": "1.0.0",
  "description": "WordPress plugin for Jobber integration",
  "scripts": {
    "start": "npm run watch",
    "watch": "10up-toolkit watch --port=5010 --hot",
    "build": "10up-toolkit build",
    "format-js": "10up-toolkit format-js",
    "lint-js": "10up-toolkit lint-js",
    "lint-style": "10up-toolkit lint-style",
    "test": "10up-toolkit test-unit-jest --passWithNoTests",
    "test:e2e": "playwright test --config=tests/e2e/config/playwright.config.js",
    "test:e2e:ui": "playwright test --ui --config=tests/e2e/config/playwright.config.js",
    "test:e2e:debug": "playwright test --debug --config=tests/e2e/config/playwright.config.js",
    "env:start": "wp-env start",
    "env:stop": "wp-env stop",
    "env:destroy": "wp-env destroy",
    "clean-dist": "rm -rf ./dist",
    "archive": "composer archive --file=$npm_package_name --format=zip",
    "postarchive": "rm -rf ./release && unzip $npm_package_name.zip -d ./release"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@wordpress/icons": "^10.22.0",
    "@wordpress/scripts": "^26.0.0",
    "playwright": "^1.52.0",
    "prop-types": "^15.7.2"
  },
  "devDependencies": {
    "10up-toolkit": "^6.4.0",
    "@10up/babel-preset-default": "^2.1.2",
    "@cspotcode/source-map-support": "^0.8.1",
    "@playwright/test": "^1.16.3",
    "@tsconfig/node10": "^1.0.11",
    "@tsconfig/node12": "^1.0.11",
    "@tsconfig/node14": "^1.0.3",
    "@tsconfig/node16": "^1.0.4",
    "@types/node": "^20.17.30",
    "@wordpress/e2e-test-utils": "^10.21.0",
    "@wordpress/env": "^8.2.0",
    "arg": "^4.1.3",
    "create-require": "^1.1.1",
    "diff": "^4.0.2",
    "dotenv": "^16.5.0",
    "jest-environment-jsdom": "^29.7.0",
    "make-error": "^1.3.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "v8-compile-cache-lib": "^3.0.1"
  },
  "10up-toolkit": {
    "entry": {
      "admin": "./assets/js/admin/admin.js",
      "jobber-forms": "./blocks/forms"
    }
  }
}
