{
  "name": "jobber",
  "version": "1.0.0",
  "description": "WordPress plugin for Jobber integration",
  "scripts": {
    "start": "npm run watch",
    "watch": "10up-toolkit watch --port=5010 --hot",
    "build": "10up-toolkit build",
    "format-js": "10up-toolkit format-js",
    "lint-js": "10up-toolkit lint-js",
    "lint-style": "10up-toolkit lint-style",
    "test": "10up-toolkit test-unit-jest --passWithNoTests",
    "test:e2e": "playwright test --config=tests/e2e/config/playwright.config.js",
    "test:e2e:ui": "playwright test --ui --config=tests/e2e/config/playwright.config.js",
    "test:e2e:debug": "playwright test --debug --config=tests/e2e/config/playwright.config.js",
    "env:start": "wp-env start",
    "env:stop": "wp-env stop",
    "env:destroy": "wp-env destroy",
    "clean-dist": "rm -rf ./dist",
    "archive": "composer archive --file=jobber --format=zip",
    "postarchive": "rm -rf ./release && unzip jobber.zip -d ./release"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@wordpress/icons": "^10.22.0",
    "@wordpress/scripts": "^26.0.0",
    "prop-types": "^15.7.2"
  },
  "devDependencies": {
    "@10up/babel-preset-default": "^2.1.2",
    "@playwright/test": "^1.52.0",
    "@wordpress/env": "^10.0.0",
    "@wordpress/scripts": "^24.6.0",
    "10up-toolkit": "^6.4.1",
    "copy-webpack-plugin": "^12.0.2",
    "dotenv": "^16.4.5",
    "jest-environment-jsdom": "^29.7.0",
    "node-wp-i18n": "^1.2.7"
  },
  "10up-toolkit": {
    "entry": {
      "jobber-forms": "./blocks/forms"
    }
  }
}
